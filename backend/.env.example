# Backend mode
PAYMENTS_STORAGE_BACKEND=local
PORT=5000

# Admin login
ADMIN_USER=Ramakrishna
ADMIN_PASS=change-me

# Firestore settings
# Switch PAYMENTS_STORAGE_BACKEND to "firestore" after one of the credential options below is configured.
FIREBASE_NAMESPACE=event-booking

# Option 1: path to a downloaded Firebase service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccountKey.json

# Option 2: inline Firebase service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com"}

# Option 3: use Google application default credentials
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json
